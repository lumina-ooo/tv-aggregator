<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme optimized for TV -->
    <style name="Theme.TVAggregator" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/tv_primary</item>
        <item name="colorPrimaryVariant">@color/tv_primary_variant</item>
        <item name="colorOnPrimary">@color/tv_on_primary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/tv_secondary</item>
        <item name="colorSecondaryVariant">@color/tv_secondary_variant</item>
        <item name="colorOnSecondary">@color/tv_on_secondary</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>

        <!-- Background colors -->
        <item name="colorSurface">@color/tv_surface</item>
        <item name="colorOnSurface">@color/tv_on_surface</item>
        <item name="android:colorBackground">@color/tv_background</item>
        <item name="colorOnBackground">@color/tv_on_background</item>

        <!-- Error colors -->
        <item name="colorError">@color/tv_error</item>
        <item name="colorOnError">@color/tv_on_error</item>

        <!-- TV-specific attributes -->
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>

        <!-- Focus and selection -->
        <item name="android:colorControlHighlight">@color/tv_focus</item>
    </style>

    <!-- TV Leanback Theme -->
    <style name="Theme.TVAggregator.Leanback" parent="Theme.TVAggregator">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowBackground">@color/tv_background</item>
    </style>
</resources>