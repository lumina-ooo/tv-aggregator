<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme - minimal, Compose handles theming -->
    <style name="Theme.TVAggregator" parent="android:Theme.NoTitleBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@color/tv_background</item>
        <item name="android:colorControlHighlight">@color/tv_focus</item>
    </style>

    <!-- TV Leanback Theme -->
    <style name="Theme.TVAggregator.Leanback" parent="Theme.TVAggregator">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowBackground">@color/tv_background</item>
    </style>
</resources>