<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Allow backup of app data -->
        <include domain="root" />
        <exclude domain="root" path="device_prefs" />
    </cloud-backup>
    <device-transfer>
        <!-- Allow transfer of app data -->
        <include domain="root" />
        <exclude domain="root" path="device_prefs" />
    </device-transfer>
</data-extraction-rules>